#!/bin/sh
# =============================================================================
# qmanager_ping — QManager Unified Ping Daemon
# =============================================================================
# The SINGLE source of internet reachability and latency data.
# All consumers (poller, watchcat, frontend) read from this daemon's output.
# This daemon NEVER touches the modem serial port.
#
# Output: /tmp/qmanager_ping.json (atomic writes, slim — no stats/history)
# History: /tmp/qmanager_ping_history (flat-file ring buffer, read by poller)
#
# Stats (avg/min/max/jitter/loss) and history JSON array are computed by the
# poller in a single awk pass over the raw history file — not here.
#
# Consumers:
#   - Poller:   reads ping.json (reachability/streaks) + history file (stats)
#   - Watchcat: reads ping.json → streak_fail drives recovery decisions
#   - Frontend: reads via status.json (merged by poller)
#
# Install location: /usr/bin/qmanager_ping
# Dependencies: ping (busybox), date, tail, mv
# =============================================================================

# --- Logging -----------------------------------------------------------------
. /usr/lib/qmanager/qlog.sh 2>/dev/null || {
    qlog_init() { :; }
    qlog_debug() { :; }
    qlog_info() { :; }
    qlog_warn() { :; }
    qlog_error() { :; }
    qlog_state_change() { :; }
}
qlog_init "ping"

# --- Configuration -----------------------------------------------------------
# Defaults — overridable via UCI (/etc/config/qmanager) when implemented
PING_TARGET_1="${PING_TARGET_1:-google.com}"
PING_TARGET_2="${PING_TARGET_2:-cloudflare.com}"
PING_INTERVAL="${PING_INTERVAL:-5}"
FAIL_THRESHOLD="${FAIL_THRESHOLD:-3}"
RECOVER_THRESHOLD="${RECOVER_THRESHOLD:-2}"
HISTORY_SIZE="${HISTORY_SIZE:-60}"
PING_TIMEOUT=2          # BusyBox ping -W timeout in seconds

# --- File Paths --------------------------------------------------------------
CACHE_FILE="/tmp/qmanager_ping.json"
CACHE_TMP="/tmp/qmanager_ping.json.tmp"
HISTORY_FILE="/tmp/qmanager_ping_history"
RECOVERY_FLAG="/tmp/qmanager_recovery_active"
PID_FILE="/tmp/qmanager_ping.pid"

# --- Carrier state ----------------------------------------------------------
# Path to the WAN interface's carrier sysfs file. Override via env to point
# at a different netdev (e.g. eth0 in dev environments).
CARRIER_FILE="${CARRIER_FILE:-/sys/class/net/rmnet_data0/carrier}"

# --- State Variables ---------------------------------------------------------
streak_success=0
streak_fail=0
reachable="true"
prev_reachable="true"
target_index=0
target_count=2
history_count=0     # tracked in shell — avoids wc -l fork every cycle

# =============================================================================
# HELPERS
# =============================================================================

# --- Check WAN-side link carrier (free, no fork) ----------------------------
# Returns: 0 = link up, 1 = link down or sysfs unreadable.
# Used as an early-exit gate before the network probe — when carrier is 0 the
# probe will fail anyway, so we skip it and write reachable=false directly.
carrier_is_up() {
    local c=
    read -r c < "$CARRIER_FILE" 2>/dev/null || return 1
    [ "$c" = "1" ]
}

# --- Execute a single ping against a target ----------------------------------
# Returns: 0 = success (RTT written to stdout), 1 = failure
do_ping() {
    local target="$1"
    local result

    result=$(ping -c1 -W"$PING_TIMEOUT" "$target" 2>/dev/null)
    [ $? -ne 0 ] && return 1

    # Pure shell RTT extraction: "...time=34.2 ms..." → "34.2"
    # No grep/cut forks needed.
    local rtt="${result##*time=}"
    rtt="${rtt%% *}"

    # Validate: must be non-empty and numeric (digits + dot only)
    case "$rtt" in
        ''|*[!0-9.]*) return 1 ;;
    esac

    echo "$rtt"
}

# --- Select next ping target (alternates between targets) --------------------
get_target() {
    if [ "$target_index" -eq 0 ]; then
        echo "$PING_TARGET_1"
    else
        echo "$PING_TARGET_2"
    fi
    target_index=$(( (target_index + 1) % target_count ))
}

# --- Write slim JSON cache atomically ----------------------------------------
# Renders the 8-scalar schema with printf — no fork, no 322 KB jq binary load.
# Output is consumed by qmanager_poller (read_ping_data) and qmanager_watchcat.
# Field names and types are exactly as before.
write_cache() {
    local rtt="$1"          # numeric like "34.2", or the literal string "null"
    local timestamp during_recovery
    timestamp=$(date +%s)
    during_recovery="false"
    [ -f "$RECOVERY_FLAG" ] && during_recovery="true"

    # Targets and interval are bare config values; we don't escape them because
    # they are operator-controlled (env file) and never contain JSON metachars
    # in any supported configuration. If you change PING_TARGET_* to accept
    # arbitrary user input from a CGI, switch to jq here.
    printf '{"timestamp":%d,"targets":["%s","%s"],"interval_sec":%d,"last_rtt_ms":%s,"reachable":%s,"streak_success":%d,"streak_fail":%d,"during_recovery":%s}\n' \
        "$timestamp" \
        "$PING_TARGET_1" "$PING_TARGET_2" \
        "$PING_INTERVAL" \
        "$rtt" \
        "$reachable" \
        "$streak_success" "$streak_fail" \
        "$during_recovery" \
        > "$CACHE_TMP"
    mv "$CACHE_TMP" "$CACHE_FILE"
}

# =============================================================================
# MAIN LOOP
# =============================================================================

main() {
    # Prevent duplicate instances
    if [ -f "$PID_FILE" ]; then
        local old_pid
        old_pid=$(cat "$PID_FILE" 2>/dev/null)
        if [ -n "$old_pid" ] && kill -0 "$old_pid" 2>/dev/null; then
            qlog_error "Another ping daemon already running (PID $old_pid), exiting"
            exit 1
        fi
        rm -f "$PID_FILE"
    fi
    echo $$ > "$PID_FILE"

    # Remove PID file on exit
    trap 'rm -f "$PID_FILE" "$CACHE_TMP"' EXIT INT TERM

    qlog_info "========================================"
    qlog_info "QManager Ping Daemon starting (PID $$)"
    qlog_info "Targets: ${PING_TARGET_1}, ${PING_TARGET_2}"
    qlog_info "Interval: ${PING_INTERVAL}s, Fail threshold: ${FAIL_THRESHOLD}, Recover threshold: ${RECOVER_THRESHOLD}"
    qlog_info "History size: ${HISTORY_SIZE}, Timeout: ${PING_TIMEOUT}s"
    qlog_info "========================================"

    # Clean up stale files from previous run
    rm -f "$CACHE_TMP"
    : > "$HISTORY_FILE"  # Start with empty history
    history_count=0

    while true; do
        local target
        target=$(get_target)

        local rtt
        rtt=$(do_ping "$target")

        if [ $? -eq 0 ] && [ -n "$rtt" ]; then
            # --- Ping succeeded ---
            streak_success=$((streak_success + 1))
            streak_fail=0

            qlog_debug "PING OK: ${target} rtt=${rtt}ms (streak_success=${streak_success})"

            # Flip reachable back to true after sustained success
            if [ "$reachable" = "false" ] && [ "$streak_success" -ge "$RECOVER_THRESHOLD" ]; then
                prev_reachable="$reachable"
                reachable="true"
                qlog_state_change "reachable" "false" "true"
            fi

            # Append to history ring buffer
            echo "$rtt" >> "$HISTORY_FILE"
        else
            # --- Ping failed ---
            rtt="null"
            streak_fail=$((streak_fail + 1))
            streak_success=0

            qlog_debug "PING FAIL: ${target} (streak_fail=${streak_fail})"

            # Only mark unreachable after sustained failure
            if [ "$reachable" = "true" ] && [ "$streak_fail" -ge "$FAIL_THRESHOLD" ]; then
                prev_reachable="$reachable"
                reachable="false"
                qlog_state_change "reachable" "true" "false"
                qlog_warn "Internet unreachable after ${FAIL_THRESHOLD} consecutive failures"
            fi

            # Append null to history
            echo "null" >> "$HISTORY_FILE"
        fi

        # Trim history using shell counter (no wc -l fork)
        history_count=$((history_count + 1))
        if [ "$history_count" -gt "$HISTORY_SIZE" ]; then
            tail -n "$HISTORY_SIZE" "$HISTORY_FILE" > "${HISTORY_FILE}.tmp"
            mv "${HISTORY_FILE}.tmp" "$HISTORY_FILE"
            history_count=$HISTORY_SIZE
        fi

        # Write slim JSON cache
        write_cache "$rtt"

        sleep "$PING_INTERVAL"
    done
}

main "$@"

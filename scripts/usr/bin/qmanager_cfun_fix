#!/bin/sh
# =============================================================================
# qmanager_cfun_fix — One-Shot Boot-Time Radio Recovery (RM520N-GL)
# =============================================================================
# Some Quectel modems occasionally boot with CFUN=0 (radio off, SIM disabled)
# instead of CFUN=1 (full functionality). The OS is alive and AT works, but
# there is no signal and no registration — the modem looks dead from the UI.
#
# This script issues a single AT+CFUN=1 at boot to guarantee the radio comes
# up. If the modem already booted at CFUN=1, the command is a harmless no-op
# (firmware accepts it and returns OK).
#
# Run once at boot by qmanager-cfun-fix.service, after qmanager-setup.service
# (so /dev/smd11 has correct permissions) and before qmanager-poller.service
# (so the radio is on by the time data collection starts).
#
# Always exits 0 — never blocks boot on radio recovery.
#
# Install location: /usr/bin/qmanager_cfun_fix
# Dependencies: qcmd
# =============================================================================

. /usr/lib/qmanager/qlog.sh 2>/dev/null || {
    qlog_init() { :; }
    qlog_info() { :; }
    qlog_warn() { :; }
}
qlog_init "cfun_fix"

# qcmd handles the /tmp/qmanager_at.lock flock so this serializes cleanly
# against the poller and any CGI traffic that may already be in flight.
result=$(/usr/bin/qcmd "AT+CFUN=1" 2>&1)
rc=$?

if [ "$rc" -eq 0 ]; then
    qlog_info "AT+CFUN=1 issued at boot (radio assured on)"
else
    qlog_warn "AT+CFUN=1 failed at boot (rc=$rc): $result"
fi

exit 0

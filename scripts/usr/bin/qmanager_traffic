#!/bin/sh
# =============================================================================
# qmanager_traffic — QManager Live Traffic Counter Daemon
# =============================================================================
# Reads /proc/net/dev every 1 s for the active cellular rmnet interface and
# writes a slim JSON snapshot to /tmp/qmanager_traffic.json. Decoupled from
# qmanager_poller so the dashboard can render speed at 1 Hz without waiting on
# the AT-bound 2 s tier.
#
# Active-interface selection (per tick, on Quectel hardware):
#   1. $NETWORK_IFACE (admin override) — wins if present in /proc/net/dev.
#   2. Cached active rmnet_data* — fast path, no detection (steady state).
#   3. detect_active_rmnet — pure-shell scan of /proc/net/route for first
#      rmnet_data* entry. Updates cache. Self-heals across platforms:
#         x5* (RM501/502): typically rmnet_data0
#         RM520N-GL:       typically rmnet_data1
#         varies after PDP bounce / SSR
#   4. rmnet_ipa0 (aggregate parent) — fallback if detection finds nothing.
#   5. Empty → emit iface=null with zeroed counters.
#
# Cache invalidation:
#   - If cached_iface vanishes from /proc/net/dev → re-detect immediately.
#   - If RX+TX deltas are zero for ZERO_TICK_THRESHOLD consecutive ticks
#     → invalidate cache, force re-detect on next tick. Catches the silent
#     failover case where the active mux moved to a different rmnet_data*.
#   - Re-detection is fork-free (pure shell `while read < /proc/net/route`).
#
# NOTE: Quectel rmnet drivers leave /sys/class/net/<iface>/operstate at
# "unknown" even when the interface is actively passing traffic, so we cannot
# gate selection on operstate. /proc/net/dev presence is the source of truth
# (mirrors the qmanager_poller approach).
#
# Counter-reset handling: a negative delta (modem SSR re-created the iface)
# causes one zero tick and reseeds the baseline.
#
# Non-Quectel platforms (dev OpenWRT): no auto-detect, no aggregate fallback;
# uses $NETWORK_IFACE or "wwan0" only.
#
# Install location: /usr/bin/qmanager_traffic
# Dependencies: awk, cat, date, mv, jq
# =============================================================================

# --- Logging -----------------------------------------------------------------
. /usr/lib/qmanager/qlog.sh 2>/dev/null || {
    qlog_init() { :; }
    qlog_debug() { :; }
    qlog_info() { :; }
    qlog_warn() { :; }
    qlog_error() { :; }
}
qlog_init "traffic"

# --- Configuration -----------------------------------------------------------
INTERVAL=1
EXPLICIT_IFACE="$NETWORK_IFACE"      # admin override; empty = auto-detect
AGGREGATE_IFACE="rmnet_ipa0"         # parent fallback when no rmnet_data* found
ZERO_TICK_THRESHOLD=5                # consecutive zero-delta ticks → invalidate
CACHE_FILE="/tmp/qmanager_traffic.json"
CACHE_TMP="/tmp/qmanager_traffic.json.tmp"

# Platform gate: on non-Quectel hosts (e.g. dev OpenWRT), disable auto-detect
# and the rmnet aggregate fallback — those interfaces don't exist there.
QUECTEL_HOST=1
if [ ! -f /etc/quectel-project-version ]; then
    QUECTEL_HOST=0
    EXPLICIT_IFACE="${NETWORK_IFACE:-wwan0}"
    AGGREGATE_IFACE=""
fi

# --- State -------------------------------------------------------------------
prev_iface=""
prev_rx=0
prev_tx=0
prev_ts=0
cached_iface=""        # remembered active rmnet_data* (cleared on invalidation)
zero_tick_count=0      # consecutive ticks with d_rx==0 && d_tx==0

# --- Helpers -----------------------------------------------------------------

# iface_in_proc <iface> — true if iface appears in /proc/net/dev
iface_in_proc() {
    grep -q "^[[:space:]]*$1:" /proc/net/dev 2>/dev/null
}

# detect_active_rmnet — echo the first rmnet_data* with a routing entry, or
# empty. Pure-shell, zero forks: reads /proc/net/route via the shell builtin.
# /proc/net/route columns are tab/space separated; first column is the iface.
# The header line starts with "Iface" which our case glob skips naturally.
detect_active_rmnet() {
    local iface rest
    while read -r iface rest; do
        case "$iface" in
            rmnet_data*)
                echo "$iface"
                return 0
                ;;
        esac
    done < /proc/net/route 2>/dev/null
    return 1
}

# pick_iface — sets global IFACE_RESULT to the iface to read this tick, or
# "" if none present. Mutates $cached_iface and $zero_tick_count on cache
# updates, so the function MUST be called directly (not via $(...)) — a
# subshell would discard those side effects.
#
# Precedence (Quectel hosts):
#   1. $NETWORK_IFACE override (if it's currently in /proc/net/dev)
#   2. cached_iface (still in /proc/net/dev) — fast path, zero forks
#   3. detect_active_rmnet — pure-shell /proc/net/route scan; updates cache
#   4. AGGREGATE_IFACE (rmnet_ipa0) — parent fallback, slightly noisier
# On non-Quectel hosts: only step 1 runs (with wwan0 as the default).
pick_iface() {
    IFACE_RESULT=""

    # 1. Explicit admin override always wins.
    if [ -n "$EXPLICIT_IFACE" ] && iface_in_proc "$EXPLICIT_IFACE"; then
        IFACE_RESULT="$EXPLICIT_IFACE"
        return
    fi

    # Non-Quectel hosts stop here — no auto-detect, no aggregate fallback.
    if [ "$QUECTEL_HOST" -eq 0 ]; then
        return
    fi

    # 2. Cached active interface — steady-state path, no detection cost.
    if [ -n "$cached_iface" ] && iface_in_proc "$cached_iface"; then
        IFACE_RESULT="$cached_iface"
        return
    fi

    # 3. Detect via /proc/net/route. Update cache on hit. detect_active_rmnet
    # is a pure echo-only function so its $(...) subshell has no side effects.
    local detected
    detected=$(detect_active_rmnet)
    if [ -n "$detected" ] && iface_in_proc "$detected"; then
        cached_iface="$detected"
        zero_tick_count=0
        IFACE_RESULT="$detected"
        return
    fi

    # 4. Fall back to the aggregate parent if the route table has nothing yet.
    if [ -n "$AGGREGATE_IFACE" ] && iface_in_proc "$AGGREGATE_IFACE"; then
        IFACE_RESULT="$AGGREGATE_IFACE"
        return
    fi
}

# read_counters <iface> — echo "rx tx" or "0 0" on miss
read_counters() {
    local iface="$1"
    awk -v ifn="${iface}:" '$1 == ifn { print $2, $10; found=1; exit }
                            END { if (!found) print "0 0" }' /proc/net/dev 2>/dev/null
}

# write_cache <iface_or_empty> <rx> <tx> <rx_per_sec> <tx_per_sec>
write_cache() {
    local iface="$1" rx="$2" tx="$3" rxps="$4" txps="$5"
    local ts
    ts=$(date +%s)
    if [ -z "$iface" ]; then
        jq -n \
            --argjson ts "$ts" \
            --argjson trx "$rx" --argjson ttx "$tx" \
            --argjson rxps "$rxps" --argjson txps "$txps" \
            '{ ts: $ts, iface: null,
               total_rx_bytes: $trx, total_tx_bytes: $ttx,
               rx_bytes_per_sec: $rxps, tx_bytes_per_sec: $txps }' \
            > "$CACHE_TMP" && mv "$CACHE_TMP" "$CACHE_FILE"
    else
        jq -n \
            --argjson ts "$ts" \
            --arg iface "$iface" \
            --argjson trx "$rx" --argjson ttx "$tx" \
            --argjson rxps "$rxps" --argjson txps "$txps" \
            '{ ts: $ts, iface: $iface,
               total_rx_bytes: $trx, total_tx_bytes: $ttx,
               rx_bytes_per_sec: $rxps, tx_bytes_per_sec: $txps }' \
            > "$CACHE_TMP" && mv "$CACHE_TMP" "$CACHE_FILE"
    fi
}

# --- Main loop ---------------------------------------------------------------
qlog_info "traffic daemon started (explicit=${EXPLICIT_IFACE:-none} aggregate=${AGGREGATE_IFACE:-none} zero_threshold=${ZERO_TICK_THRESHOLD} interval=${INTERVAL}s)"

while :; do
    # pick_iface mutates $cached_iface and $zero_tick_count, so call it
    # directly (no $() — that would discard cache updates to a subshell).
    pick_iface
    iface="$IFACE_RESULT"

    if [ -z "$iface" ]; then
        write_cache "" 0 0 0 0
        prev_iface=""
        prev_rx=0
        prev_tx=0
        prev_ts=0
        zero_tick_count=0
        sleep "$INTERVAL"
        continue
    fi

    set -- $(read_counters "$iface")
    rx="${1:-0}"
    tx="${2:-0}"
    now_ts=$(date +%s)

    rxps=0
    txps=0
    d_rx=0
    d_tx=0

    # Compute deltas only when iface is unchanged AND we have a prior baseline.
    # On iface change or first run, just seed the baseline.
    if [ "$iface" = "$prev_iface" ] && [ "$prev_ts" -gt 0 ]; then
        elapsed=$((now_ts - prev_ts))
        [ "$elapsed" -lt 1 ] && elapsed=1

        d_rx=$((rx - prev_rx))
        d_tx=$((tx - prev_tx))

        # Negative delta = counter reset (SSR / iface bounce). Emit 0 this tick.
        [ "$d_rx" -lt 0 ] && d_rx=0
        [ "$d_tx" -lt 0 ] && d_tx=0

        rxps=$((d_rx / elapsed))
        txps=$((d_tx / elapsed))
    fi

    write_cache "$iface" "$rx" "$tx" "$rxps" "$txps"

    # --- Cache invalidation: zero-delta-tick threshold -----------------------
    # Only meaningful when we're currently using a cached rmnet_data* (i.e. not
    # the admin override or the rmnet_ipa0 aggregate fallback). If both deltas
    # are zero for ZERO_TICK_THRESHOLD ticks in a row, the active mux may have
    # silently moved — invalidate and force re-detection on the next tick.
    if [ "$iface" = "$cached_iface" ] && [ -n "$cached_iface" ]; then
        if [ "$d_rx" -eq 0 ] && [ "$d_tx" -eq 0 ]; then
            zero_tick_count=$((zero_tick_count + 1))
            if [ "$zero_tick_count" -ge "$ZERO_TICK_THRESHOLD" ]; then
                qlog_debug "iface=$iface idle for ${zero_tick_count} ticks; invalidating cache"
                cached_iface=""
                zero_tick_count=0
            fi
        else
            zero_tick_count=0
        fi
    else
        zero_tick_count=0
    fi

    prev_iface="$iface"
    prev_rx="$rx"
    prev_tx="$tx"
    prev_ts="$now_ts"

    sleep "$INTERVAL"
done
